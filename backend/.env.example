# ===== Banco de dados =====
# Local (padrao, sem instalar nada): SQLite
DATABASE_URL="file:./dev.db"
# Producao multiusuario (alternativa): PostgreSQL
# DATABASE_URL="postgresql://escala:escala@localhost:5432/escala_gru?schema=public"

# ===== Servidor =====
PORT=4000
NODE_ENV=development
# Origens permitidas (CORS), separadas por virgula
CORS_ORIGIN=http://localhost:5173

# ===== Autenticacao =====
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h
# Usuario administrador criado pelo seed
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@escala.local
ADMIN_PASSWORD=admin123

# ===== Excel =====
# Pasta monitorada. Qualquer .xlsx alterado/adicionado aqui e importado.
EXCEL_WATCH_DIR=../excel
# (Opcional) caminho fixo de um arquivo a importar no boot. Vazio = usa o mais recente da pasta.
EXCEL_FILE=
# Nome da aba de legenda
EXCEL_LEGEND_SHEET=LEGENDA
# Debounce (ms) para aguardar o arquivo terminar de ser gravado
EXCEL_STABILITY_MS=2500

# ===== Backup =====
BACKUP_DIR=../backups
# Cron diario as 00:00
BACKUP_CRON=0 0 * * *
BACKUP_KEEP=30
# Caminho do pg_dump (deixe "pg_dump" se estiver no PATH)
PG_DUMP_BIN=pg_dump

# ===== Rate limit =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
